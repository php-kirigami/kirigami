    "js-yaml": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/php-kirigami/kirigami.git"
  },
  "homepage": "https://github.com/php-kirigami/kirigami/tree/main/packages/php-prepros#readme",
  "bugs": {
