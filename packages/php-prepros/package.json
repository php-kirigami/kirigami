{
  "name": "@kirigami/php-prepros",
  "version": "1.0.1",
  "description": "PHP preprocessor for the Kirigami static site generator. Compile PHP page templates to clean, deployable HTML — with zero server dependency.",
  "keywords": [
    "kirigami",
    "php",
    "preprocessor",
    "static-site-generator",
    "ssg",
    "wasm",
    "php-wasm",
    "markdown",
    "yaml",
    "github-pages",
    "pages"
  ],
  "license": "MIT",
  "author": "Maxime Larrivée-Roy",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.2.3"
  },
  "exports": {
